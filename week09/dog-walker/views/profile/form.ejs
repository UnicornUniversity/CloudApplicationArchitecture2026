<head>
    <title>Dog Owner Profile</title>
    <%- include("../shared/css.ejs") %>
</head>
<body>
    <%- include("../shared/navbar.ejs") %>
    <div class="container">
        <div class="row">
            <div class="col-sm">
            </div>
            <div class="col-sm">
                <form method="post" action="/profile/save" enctype="multipart/form-data">
                    <div class="form-group">
                        <label for="dogName">Dog Name</label>
                        <input type="text" class="form-control" id="dogName" name="dogName"  />
                    </div>
                    <div class="form-group">
                        <label for="dogSize">Dog Size</label>
                        <select type="text" class="form-control" id="dogSize" name="dogSize">
                            <option value="0">5 kg and less</option>
                            <option value="1">6-14 kg</option>
                            <option value="2">15 kg and more</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="dogPortrait">Dog Portrait</label>
                        <input type="file" name="dogPortrait" id="dogPortrait" accept="image/png, image/jpeg" />
                    </div>
                    <button type="submit" style="margin-top: 20px" class="btn btn-primary">Submit</button>
                </form>
            </div>
            <div class="col-sm">
            </div>
        </div>
    </div>
</body>