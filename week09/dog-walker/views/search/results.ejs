<head>
    <title>Search</title>
    <%- include("../shared/css.ejs") %>
</head>
<body>
<%- include("../shared/navbar.ejs") %>

<div class="container">
    <div class="row">
        <div class="col-sm">
        </div>
        <div class="col-sm">
            <h3>Results</h3>

            <% if (results.length > 0) { %>
                <% for(let dog of results) { %>
                <div class="card" style="width: 18rem;">
                    <img class="card-img-top" src="..\<%= dog.dogUrl %>" alt="dog name" />
                    <div class="card-body">
                        <h5 class="card-title"><%= dog.dogName %></h5>
                        <a href="#" class="btn btn-primary">Message</a>
                    </div>
                </div>
                <% } %>
            <% } else { %>
                <h3>No dogs found</h3>
            <% }%>
        </div>
        <div class="col-sm">
        </div>
    </div>
</div>
</body>