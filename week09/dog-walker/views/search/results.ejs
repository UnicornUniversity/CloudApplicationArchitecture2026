<head>
    <title>Search Results</title>
    <%- include("../shared/css.ejs") %>
</head>
<body>
<div class="container">
    <div class="col-sm">
        <h3>Results</h3>

        <% if (results.length > 0) { %>
            <% for(let i = 0; i < results.length; i++){ %>
                <% const dog = results[i]; %>
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title"></h5>
                        <p class="card-text"><%= dog.dogName %></p>
                    </div>
                </div>
            <% } %>
        <% } %>
    </div>
</div>
</body>